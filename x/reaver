# If you have already started a Reaver session, this will resume from
# snapshot.
#
# Otherwise, it will build reaver, load the standard library, exit,
# and then *then* resume from the new snapshot created through this.

set -ex

hsbuild () {
	ghc -O2 -isrc/hs -outputdir .build -main-is Wisp src/hs/Wisp.hs -o Wisp
}

reset () {
	./Wisp src/plan reaver main
}

repl () {
	./Wisp snap root _ # run from snapshot
}

load_stdlib () {
    repl <<EOF
(#bind stdlib (#module stdlib))
(#import stdlib)
:todo
(#import todo)
EOF
}


hsbuild

if [[ "$1" == "--reset" || ! -e snap/root.plan ]]
then reset; load_stdlib
fi

repl
