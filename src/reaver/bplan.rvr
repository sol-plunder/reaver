;;; RPLAN ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(#bind R (#pin "R"))

(#macro rplan
  (#fun pin noinline "rplan" (rplan _ u g _ _ x)
    (#let ((sig (Ix 1 x)))
      (#let ((nam (Ix 0 (Ix 0 sig))))
        (0 u g
          (0 "#bind" nam
            (0 "#fun" "pin" "noinline" (1 nam) (Up 0 nam sig)
              (0 (1 R) sig))))))))

(rplan ("Input" bytes))
(rplan ("Output" bytes))
(rplan ("Warn" bytes))


;;; Essentials ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(#bind drop
  (#fun pin noinline "drop" (_ n row)
    (Slice n (Sz row) row)))

(#bind _0 Ix0)
(#bind _1 Ix1)
(#bind _2 Ix2)
(#bind _3 Ix3)
(#bind _4 Ix4)
(#bind _5 Ix5)
(#bind _6 Ix6)
(#bind _7 Ix7)
(#bind _8 (Ix 8))
(#bind _9 (Ix 9))
