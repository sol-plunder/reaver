(#bind B (#pin "B"))

(#bind Ix
  (#fun pin noinline "Ix" (Ix i r)
    (B ("Ix" i r))))

(#bind Up
  (#fun pin noinline "Up" (Up i v r)
    (B ("Up" i v r))))

(#macro bplan
  (#fun pin noinline "bplan" (bplan _ u g _ _ x)
    (#let ((sig (Ix 1 x)))
      (#let ((nam (Ix 0 (Ix 0 sig))))
        (0 u g
          (0 "#bind" nam
            (0 "#fun" "pin" "noinline" (1 nam) (Up 0 nam sig)
              (0 (1 B) sig))))))))

(bplan ("Pin" x))
(bplan ("Law" a m b))
(bplan ("Elim" p l a z m o))
(bplan ("Inc" x))
