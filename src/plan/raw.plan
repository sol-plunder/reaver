(#bind id
  (#pin
    (#law "id" (id x) x)))

(#law "unwrapped" (foo x) (#(id) x)) ; no constant wrapper

(#law "wrapped" (bar x) (id x))    ; constant wrapper

( (#law "eat" (_ x)   #(0))    ; manual expression splicing (self-ref)
  0 0 0 0 0 0 0 0)

(#law "letted" (bar x)
  x1(1 x)
  x11(1 x1)
  (0 x1 x11))
