assert( planEq (Row 3   4   [1 [2 Inc]])        (3 1 2 0 0) )
assert( planEq (Row Row 4   [1 [2 3 4]])        [1 2 0 0]   )
assert( planEq (Row 3   Row [1 [2 3 4]])        3           )

assert(planEq "a"               (Rep "a" "v" 0))
