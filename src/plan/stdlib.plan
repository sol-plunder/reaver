;;; Conveniences ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

( defun (odd x)         (Test 0 x)    )
( defun (even x)        (Nil (odd x)) )
( defun (flip f x y)    (f y x)       )
( defun (id x)          x             )
( defun (const x y)     x             )
( defun (compose f g x) (f (g x))     )

(defun (max x y) (If (Ge x y) x y))
(defun (min x y) (If (Le x y) x y))

(defun (take n row) (Row 0 n (streamed 0 n row)))

(defun (^ env x)
  sym(Ix0 (Ix1 x))
  (Ifz (Nat sym)
    (Error ("#: bad input" x))
    [(1 sym) sym]))


;;; Nicer Syntax for Lambdas ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(defun (splitArrow i items)
  x(Ix i items)
  (Ifz x
    ["_" (Init items) [(Last items)]]
    (If (Eq x ".")
      ["_" (take i items) (drop (Inc i) items)]
      (If (Eq x "->")
        (["_" (take i items) (drop (Inc i) items)])
        (If (Eq x "=>")
          [(Ix0 items) (drop 1 (take i items)) (drop (Inc i) items)]
          (splitArrow (Inc i) items))))))

(assert
  (planEq
    ["_" ["a" "b"] ["b"]]
    (splitArrow 0 ["a" "b" "->" "b"])))

(defun (splitCurly items)
  (splitArrow 0 items))

; {args.. -> body..) =>
;
;    (law (0 args..) body..)
;
; {self args.. => body..} =>
;
;   (law (self args..) body..)

(defun (Unself self)
  (If (Eq "_" self) 0
    (If (IsNat self) self
      (Ix0 self))))

(defun (curly-syntax law-macro ws x)
  split(splitArrow 0 (drop 1 x))
  self(Unself (Ix0 split))
  args(Ix1 split)
  body(Ix2 split)
  (weld [law-macro (1 self) (cons self args)] body))

; TODO: just live without this until lambda.wisp

(defmacro (#curl ws x)
  (curly-syntax "#law" ws x))

assert(Eq 3 ({a b -> b}   2 3))
assert(Eq 3 ({f a b => b} 2 3))


