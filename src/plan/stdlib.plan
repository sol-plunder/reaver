;;; Appending to Arrays ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(defun (resize n array)
  (Row 0 n (stream array)))

(defun (snoc xs x)
  (xs x))

(tests
  ( [0 0 0 0 0]  (resize 5 0)       )
  ( [1 2 3 0 0]  (resize 5 [1 2 3]) )
  ( [1 2 3 4]    (snoc [1 2 3] 4)   )
