assert(not (Ne 4 4))
assert(not (Gt 4 4))

assert(Eq 2 Sz(0 1 2))
assert(Eq 0 (And 0 3))
assert(Eq 3 (And 1 3))
assert(Eq 3 (Or 3 4))
assert(Eq 4 (Or 0 4))

assert(Eq 9 (If 1 9 (Error 4)))
assert(Eq 0 (And 0 (Error 4)))
assert(Eq 3 (Or 3 (Error 5)))

assert(Eq 3 (Ifz 0 3 4))
