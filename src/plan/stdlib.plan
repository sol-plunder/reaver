(defun (streamed-rev rem row)
  i(Dec rem)
  (And rem
    (0 (Ix i row) (streamed-rev i row))))

(defun (stream-rev row)
  (streamed-rev (Sz row) row))

(tests
  ( [3 [2 [1 []]]]
    (stream-rev [1 2 3])))


;; Misc ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(defun (dup x)
  [x x])


;; Lists ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(def NIL 0)(def CONS 0)(def lcons 0)

(defun (lgenfrom i n f) (And (Lt i n) (CONS (f i) (lgenfrom (Inc i) n f))))
(defun (lgen n f)       (lgenfrom 0 n f))
(defun (gen n f)        (Row 0 n (lgen n f)))

(defun (linterLoop sep list)
  (And list
    [sep [ (Ix0 list)
           (linterLoop sep (Ix1 list)) ]]))

(defun (lintersperse sep list)
  x(Ix0 list)
  xs(Ix1 list)
  (And list (lcons x (linterLoop sep xs))))

(tests
  ( (lintersperse 3 [0 [1 [2 0]]])
    [0 [3 [1 [3 [2 0]]]]]))

(defun (lfoldl f z0 l)
  z1(f z0 (Ix0 l))
  (Ifz l z0
    (Seq z1
      (lfoldl f z1 (Ix1 l)))))

(defun (lfoldr f z l)
  (Ifz l z
    (f (Ix0 l) (lfoldr f z (Ix1 l)))))

(defun (foldr-loop f z row i rem)
  (Ifz rem z
    (f (Ix i row)
      (foldr-loop f z row (Inc i) (Dec rem)))))

(defun (foldr f z row)
  (foldr-loop f z row 0 (Sz row)))

(defun (foldr1 f row)
  (foldr-loop f (Last row) row 0 (Dec (Sz row))))

(tests
  (0         (foldr1 Add []))
  (3         (foldr1 Add [3]))
  (3         (foldr1 Sub [3]))
  (6         (foldr1 Add [1 2 3]))
  ([1 [2 3]] (foldr1 0   [1 2 3])))

(defun (unzip pairs)
  [ (map .0 pairs) (map .1 pairs) ])

(defun (llen xs)
  (lfoldl (#law 0 (() x _) (Inc x)) 0 xs))

(defun (foldl-loop f row acc i rem)
  (Seq2 i acc
    (Ifz rem acc
      (foldl-loop f row (f acc (Ix i row)) (Inc i) (Dec rem)))))

(defun (foldl f z row)
  (foldl-loop f row z 0 (Sz row)))

(tests
  (10 (foldl Add 1 [2 3 4])))

(defun (ifoldl-loop f row acc i rem)
  (Seq2 i acc
    (Ifz rem acc
      (ifoldl-loop f row (f i acc (Ix i row)) (Inc i) (Dec rem)))))

(defun (ifoldl f z row)
  (ifoldl-loop f row z 0 (Sz row)))

( defun (lrev xs)      (lfoldl {x y -> [y x]} NIL xs) )
( defun (cons x xs)    (weld [x] xs)                  )
( defun (lsing x)      [x 0]                          )
( defun (lcat ls)      (lfoldr lweld NIL ls)          )
( def   ~              stream                         )

(defun (rev xs)
  (Row 0 (Sz xs) (lrev (stream xs))))

(tests
  ( ~[1 2 3]
    [1 [2 [3 0]]] )

  ( (lrev ~[1 2 3])
    ~[3 2 1] )

  ( (rev [1 2 3])
    [3 2 1] )

  ( 3 (llen ~[1 2 3]))

  ( ~[1 2 3 4 5 6]
    (lcat ~[~[1] ~[2 3] ~[] ~[4 5 6]])))

(defun (strGenLoop n f acc i)
  (Seq acc
    (If (Ge i n) acc
      (strGenLoop n f (Store8 i (f i) acc) (Inc i)))))

(defun (strGen n f)
  (strGenLoop n f 0 0))

(defun (lexplode-step str i)
  (Load8 i str))

(defun (lexplode str)
  (lgen (Bytes str) (lexplode-step str)))

(defun (limpLoop i acc list)
  x(Ix0 list)
  xs(Ix1 list)
  (Seq2 i acc
    (Ifz list acc
      (limpLoop (Inc i) (Store8 i x acc) xs))))

(defun (limplode list)
  (limpLoop 0 0 list))

(tests
  ("abc" (limplode (lexplode "abc"))))

(defun (lfilter f l)
  x(Ix0 l)
  rest(lfilter f (Ix1 l))
  (And l
    (If (f x) [x rest] rest)))

(defun (lsz l)
  (lfoldr {x acc -> (Inc acc)} 0 l))

(defun (array l)
  (Row 0 (lsz l) l))

(defun (filter f row)
  (array (lfilter f (stream row))))

(defun (lall-step f x)
  (Nil (f x)))

(defun (lall f l)
  (Nil (lfilter (lall-step f) l)))

(tests
  (1 (lall even ~[0 2 4]))
  (0 (lall even ~[0 1 2 4])))

(defun (strAll f str)
  (lall f (lexplode str)))

(defun (all f xs)
  (lall f (stream xs)))

(tests
  ((lfilter even ~[1 2 3 4]) ~[2 4])
  ((lfilter odd ~[1 2 3 4])  ~[1 3]))

(defun (lenumFrom n)
  (Seq n
    [n (lenumFrom (Inc n))]))

(tests
  ( (lsz ~[1 2 3 4])        4            )
  ( (array ~[1 2 3 4])      [1 2 3 4]    ))

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(defun (lindy i list)
  (And list
    (Seq i
      [[i (Ix0 list)] (lindy (Inc i) (Ix1  list))])))

(defun (lzip xlist ylist)
  x(Ix0 xlist)
  xs(Ix1 xlist)
  y(Ix0 ylist)
  ys(Ix1 ylist)
  (And xlist
    (And ylist
      [[x y] (lzip xs ys)])))

(defun (zip x y)
  (Row 0 (min (Sz x) (Sz y))
    (lzip (stream x) (stream y))))

(tests
  ( [[3 "three"] [4 "four"] [5 "five"]]
    (zip [3 4 5] ["three" "four" "five" "six"])))

(defun (lmap f l)
  (And l
    [ (f (Ix0 l)) (lmap f (Ix1 l))]))

(defun (lmapi-loop f i l)
  (Seq i
    (And l
      [ (f i (Ix0 l))
        (lmapi-loop f (Inc i) (Ix1 l)) ])))

(defun (lmapi f l)
  (lmapi-loop f 0 l))

(tests
  (
    ~[1 2 3]
    (lmap Inc ~[0 1 2])
  )
  (
    (lmapi 0 ~[3 4 5])
    ~[[0 3] [1 4] [2 5]]
  )
)


;;; Strings ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(defun (strWeld a b)
  (Add (Lsh b (Lsh (Bytes a) 3)) a))

(tests
  ("asdf" (strWeld "" "asdf"))
  ("asdf" (strWeld "a" "sdf"))
  ("asdf" (strWeld "as" "df"))
  ("asdf" (strWeld "asd" "f"))
  ("asdf" (strWeld "asdf" "")))

(defun (lstrcat xs)
  (lfoldl strWeld 0 xs))

(tests
  ("abcdef" (lstrcat ~["ab" "cd" "ef"])))

(defun (decimal n)
  (And n
    [(Mod n 10) (decimal (Div n 10))]))

(defun (showNat n)
  (Ifz n "0"
    (lstrcat (lrev (lmap (Add "0") (decimal n))))))

(tests
  ("abcdefg" (lstrcat ~["a" "bc" "d" "" "efg"])))

(tests
  ("0"   (showNat 0))
  ("1"   (showNat 1))
  ("100" (showNat 100)))


;;; Quoting ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(defmacro (' env x)
  (1 (Ix0 (Ix1 x))))

(tests
  ("x"                       '(x))
  (["a" "b"]                 '((a b)))
  (["#brak" "a" "b"]          '([a b]))
  (["#juxt" "x" ["a"]]        '(x(a)))
  (["#juxt" "x" ["#brak" "a"]] '(x[a]))
  (["#juxt" "x" ["#curl" "a"]] '(x{a}))
  (["#juxt" "x" (1 "a")]      '(x"a")))


;;; Destructuring ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

; BindAst = Sym | [Sym, Row BindAst]
;   sym         -- plain name
;   [nm flds]   -- alias with named fields: nm[f0 f1 ...]
; All patterns must have a name. Nesting is supported.

(defun (ixExp n x)
  [(1 (Case3 n Ix0 Ix1 (Ix n))) x])

(tests
  ((ixExp 0 "a") [(1 Ix0) "a"]))

(defun (destroyField nm i f)
  (And (Ne f "_")
    ~[[f (ixExp i nm)]]))

(defun (destroyBind bind)
  nm(Ix0 bind)
  fields(Ix1 bind)
  (If (IsNat bind) [bind NIL]
    (Ifz nm Error("pattern requires a name: use x[a b c] not [a b c]" bind)
      [nm (lcat (lmapi (destroyField nm) (stream fields)))])))

(defun (destroyLets lets)
  l(Ix0 lets)
  rest(Ix1 lets)
  bind(Ix0 l)
  expr(Ix1 l)
  temp(destroyBind bind)
  nm(Ix0 temp)
  more(Ix1 temp)
  (And lets
    [[nm expr] (destroyLets (lweld more rest))]))

; destroy : List BindAst -> Row Sym -> List (Sym, Exp)
;           -> (Row Sym, Row (Sym, Exp))

(defun (destroy args nuvars lets)
  step(destroyBind (Ix0 args))
  (Ifz args
    [nuvars (array (destroyLets lets))]
    (destroy (Ix1 args)
      (nuvars (Ix0 step))
      (lweld (Ix1 step) lets))))

(tests
  ((destroy ~["aa" ["bb" ["xx" "yy" "zz"]]] 0 0)
   [["aa" "bb"]
    [["xx" [(1 Ix0)    "bb"]]
     ["yy" [(1 Ix1)    "bb"]]
     ["zz" [(1 (Ix 2)) "bb"]]]]])

(tests
  ((1 "hi")              '("hi"))
  (["#juxt" "x" (1 "hi")] '(x"hi")))

; parse-bind : Sexp -> BindAst
;   sym         -> sym
;   [a b c]     -> error (no name)
;   x[a b c]    -> ["x" ["a" "b" "c"]]
;   x[a b[c d]] -> ["x" ["a" ["b" ["c" "d"]]]]  (nested)

(defun (parse-bind bind)
  hed(Ix0 bind)
  (If (IsNat bind) bind
    (If (Eq "#brak" hed)
      Error("pattern requires a name: use x[a b c] not [a b c]" bind)
      (If (Ne "#juxt" hed) Error("parse-bind: bad pattern" bind)
        (If (Ne 3 (Sz bind)) Error("parse-bind: bad juxt size" bind)
          [(Ix1 bind) (map parse-bind (drop 1 (Ix2 bind)))])))))

(tests
  ((parse-bind '(res))        "res"              )
  ((parse-bind '(res[pp qq])) ["res" ["pp" "qq"]]))

(defun (is-curl-let? x)
  (And (Eq 4 (Sz x))
    (And (Eq "#curl" (Ix0 x))
      (Eq "=" (Ix2 x)))))

(defun (is-juxt-let? let)
  (And (Eq 3 (Sz let))
    (And (Eq "#juxt" (Ix0 let))
      (IsNat (Ix1 let)))))

(defun (parse-let let)
  bind(parse-bind (Ix1 let))
  (If (is-curl-let? let)   [ bind (Ix3 let) ]
    (If (is-juxt-let? let) [ bind (Ix2 let) ]
      Error("badlet" let))))

(tests
  ((is-juxt-let? '( x(3)         )) 1)
  ((is-curl-let? '( x(3)         )) 0)
  ((parse-let    '( x(3)         )) ["x"             (0 (1 3))])
  ((parse-let    '( {x      = 3} )) ["x"             (1 3)])
  ((parse-let    '( {a[x y] = 3} )) [["a" ["x" "y"]] (1 3)]))

; (lambda (self args..) (let) (let) body)

(defun (letExp bx)
  nm(Ix0 bx)
  bd(Ix1 bx)
  ["#juxt" nm bd])

(defun (sum xs)      (foldl Add 0 xs))
(defun (lsum xs)     (lfoldl Add 0 xs))
(defun (sum-of f xs) (lsum (lmap f (stream xs))))

(defun (lcatmap f r)
  (lcat (lmap f r)))

(defun (cat vs)
  (Row 0 (sum-of Sz vs) (lcatmap stream (stream vs))))

(tests
  (6
   (sum-of Sz [[] [1] [2 3] [4] [] [5 6] []]))

  ([1 2 3 4 5 6]
   (cat [[] [1] [2 3] [4] [] [5 6] []])))

(defun (funExp tagS self body pair)
  args(Ix0 pair)
  lets(Ix1 pair)
  (cat
    [["#law" tagS (cons self args)]
     (map letExp lets)
     [body]]))

(defmacro (patlaw env x)
  tagS(Ix1 x)
  sigS(Ix2 x)
  self(Unself (Ix0 sigS))
  args(map parse-bind (drop 1 sigS))
  lets(stream (map parse-let (Init (drop 3 x))))
  body(Last x)
  (Trace x
  (funExp tagS self body (destroy (stream args) 0 lets))))

; Redefine curly syntax to support destructuring

(defmacro (#curl ws x)
  (curly-syntax "patlaw" ws x))

; (defun (f x) bind body)

; (defun (f x) ..)
;
; (bind f 0 0
;   (pin
;     (patlaw (f x) ..))
;   "f")

(defun (is-quoted-constant x)
  (And
    (Eq 1 (Sz x))
    (Eq 1 (Hd x))))

(defun (get-sig-name sig)
  hed(Ix0 sig)
  quo(Ix0 hed)
  (If (IsNat hed) hed
    (If (And (is-quoted-constant hed) (IsNat quo)) quo
      Error("get-sig-name" "bad signature" sig))))

(tests
  ("f" (get-sig-name '((f x))))
  ("f" (get-sig-name '(("f" x)))))

(defun (fancy-bind-function isMacro e x)
  sig(Ix1 x)
  nam(Unself (get-sig-name sig))
  rest(drop 2 x)
  [(If isMacro "#macro" "#bind") nam
    ["#pin" (Weld ["patlaw" (1 nam) sig] rest)]])

(#macro patfun   (fancy-bind-function 0))
(#macro patmacro (fancy-bind-function 1))

(patmacro (defmacro _ _)
  Error("use patmacro instead"))

(patmacro (defun _ _)
  Error("use patfun instead"))

(patfun (uncurry fun @[a1 a2])
  {res[pp qq] = (fun a1 a2)}
  res)

(tests
  (7 (uncurry Add [3 4])))


;;; More List Operations ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(patfun (countdown n)
  m(Dec n)
  (And n
    (Seq m
      [m (countdown m)])))

(tests
  ((countdown 3) ~[2 1 0]))

(patfun (ltake n list[x xs])
  (And n
    (And list
      [x (ltake (Dec n) xs)])))

(patfun (ldrop n l)
  (Ifz n l
    (ldrop (Dec n) (Ix1 l))))

(tests
  ( (ltake 5 (lenumFrom 0))            ~[0 1 2 3 4] )
  ( (ltake 5 (ldrop 2 (lenumFrom 0)))  ~[2 3 4 5 6] ))

(patfun (ldropWhile f list[x xs])
  (And list
    (If (f x) (ldropWhile f xs)
      list)))

(patfun (ltakeWhile f list[x xs])
  (And list
    (And (f x)
      (0 x (ltakeWhile f xs)))))

(patfun (lfoldrix f z l0 i)
  x(Ix0 l0)
  l(Ix1 l0)
  (Seq i
    (Ifz l0 z
      (f i x (lfoldrix f z l (Inc i))))))

(patfun (lfoldri f z l)
  (lfoldrix f z l 0))

(lfoldri "f" "END" ~[1 2 3])

(tests
  ( (lindy 0 ~[3 4 5])
    ~[[0 3] [1 4] [2 5]] ))

(patfun (lcat-rows list-of-rows)
  (lcatmap stream list-of-rows))

(tests ((lcat-rows ~[[3 4] 0 [5 6 7]])
        ~[3 4 5 6 7] ))


;;; Character Classes ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(patfun (packClass strs)
  (lfoldl (flip Set) 0 (lcatmap lexplode (stream strs))))

(patfun (inClass charClass i)
  (Test i charClass))

(patfun (unpackClass ccls)
  (lstrcat
    (lfilter (inClass ccls)
      (ltake (Bits ccls)
        (lenumFrom 0)))))

(def lowers "abcdefghijklmnopqrstuvwxyz")
(def uppers "ABCDEFGHIJKLMNOPQRSTUVWXYZ")
(def digits "0123456789")
(def specials "!#$%&'*+,-./:=?@\^_`|~<>")
(def matchers "()[]{}")
(def alphaNums (lstrcat ~[lowers uppers digits]))
(def tab 9)
(def newline 10)
(def space 32)
(def spaces (lstrcat ~[tab newline space]))
(def semi ";")
(def dquote 34) ; double-quote character

(def lowChrs   (packClass [lowers]))
(def uprChrs   (packClass [uppers]))
(def symChrs   (packClass [lowers uppers digits specials]))
(def spcChrs   (packClass [spaces]))
(def natChrs   (packClass [digits]))
(def prnChrs   (packClass [alphaNums specials matchers spaces semi]))
(def opnChr    (packClass ["([{"]))
(def alnumChrs (packClass [alphaNums]))

(tests
  ("([{"        (unpackClass opnChr)  )
  ("0123456789" (unpackClass natChrs) ))

(patfun (isAlnum c)       (Test c alnumChrs))
(patfun (isNatChr c)      (Test c natChrs))
(patfun (isLower c)       (Test c lowChrs))
(patfun (isUpper c)       (Test c uprChrs))
(patfun (isSymChr c)      (Test c symChrs))
(patfun (isSpcChr c)      (Test c spcChrs))
(patfun (isPrint c)       (Test c prnChrs))
(patfun (strNoneStep f c) (Nil (f c)))
(patfun (strNone f s)     (strAll (strNoneStep f) s))

(tests
  ((unpackClass symChrs)
   (strWeld "!#$%&'*+,-./0123456789:<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ"
            "\^_`abcdefghijklmnopqrstuvwxyz|~"))

  ( (strAll  isSymChr "abcDEF345_^!'"               ) 1)
  ( (strNone isSymChr " ()[]{};"                    ) 1)
  ( (strNone isNatChr  "abcdefghijklmnopqrstuvwxyz" ) 1)
  ( (strNone isNatChr  "ABCDEFGHIJKLMNOPQRSTUVWXYZ" ) 1)
  ( (strAll  isNatChr  "01234556789"                ) 1)
  ( (strAll  isUpper   "BIND"                       ) 1)
  ( (strNone isNatChr  "_~!@#$%^&*-=|/\:?,."        ) 1)
  ( (strNone isNatChr  " ()[]{};"                   ) 1)

  ( (lall isSpcChr                  ~[" " 9 10]) 1 )
  ( (lall {x -> (Nil (isSpcChr x))} ~["a" "("])  1 ))


;;; Even More List Operations ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(def lhead Ix0)
(def ltail Ix1)

(patfun (linit xs)
  (Ifz (Ix1 xs) 0
    (lcons (Ix0 xs) (linit (Ix1 xs)))))

(patfun (llast xs)
  (Ifz (Ix1 xs) (Ix0 xs)
    (llast (Ix1 xs))))

(tests
  ( ~[3 4] (linit ~[3 4 5]) )
  ( 5      (llast ~[3 4 5]) ))


(patfun (lsnoc list[x xs] v)
  (Ifz list (lsing v)
    [x (lsnoc xs v)]))

(patfun (lhas e list[x xs])
  (And list
    (Or (Eq e x)
      (lhas e xs))))

(patfun (lfind-loop i e list[x xs])
  (Seq i
    (And list
      (If (Eq e x) [i]
        (lfind-loop (Inc i) e xs)))))

(patfun (lfind e list)
  (lfind-loop 0 e list))

(patfun (lfind-known e list)
  (lhead (lfind e list)))

(patfun (lsearch-loop e row n i)
  (If (Ge i n) i
    (If (Eq e (Ix i row)) i
      (lsearch-loop e row n (Inc i)))))

(patfun (lsearch e row)
  (lsearch-loop e row (Sz row) 0))

(tests
  (3 (lsearch 0 [1 3 5]))
  (0 (lsearch 1 [1 3 5]))
  (3 (lsearch 2 [1 3 5]))
  (1 (lsearch 3 [1 3 5]))
  (3 (lsearch 4 [1 3 5]))
  (2 (lsearch 5 [1 3 5]))
  (3 (lsearch 6 [1 3 5]))
  (3 (lsearch 7 [1 3 5])))

(patfun (lany f list[x xs])
  (And list
    (Or (f x)
      (lany f xs))))

(patfun (any f row)
  (lany f (stream row)))

(patfun (lrange i)
  (Seq i
    [i (lrange (Inc i))]))

(patfun (lix i list[x xs])
  (And list
    (Ifz i x
      (lix (Dec i) xs))))

(patfun (lix-error ctx i list[x xs])
  (Ifz list
    Error("lix-error" ctx)
    (Ifz i x
      (lix-error ctx (Dec i) xs))))

(patfun (lrep i n)
  (lgen n (const i)))

(patfun (tstep f old[s0 acc] x0)
  {@[s1 x1] = (f s0 x0)}
  [s1 (acc x1)])

(patfun (traverse st f row)
  (lfoldl (tstep f) [st 0] (stream row)))

(tests
  ( (traverse 5 (#law 0 (_ st x) [(Inc st) (Add st x)]) [3 4 5])
    [8 [8 10 12]] ))


;;; Ordering ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(defval LT 0)
(defval EQ 1)
(defval GT 2)
