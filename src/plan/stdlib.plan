;;;; Basic Standard Library
;;;; ======================
;;;;
;;;; This contains a wide range of random definitions, many of which
;;;; were created during testing and are not actually used.
;;;;
;;;; This is the largest file in the Reaver boot, and the messiest,
;;;; and it should be cleaned up.
;;;;
;;;; The structure of this file is somewhat unavoidably haphazard, since
;;;; we need to define everything from scratch, the structure resists being
;;;; broken up into clean sections.
;;;;
;;;; For example, we define some functions on lists, and then we use
;;;; those in the implementation of destructuring macros, and then we use
;;;; *those* to define more list functions.
;;;;
;;;; If we had a clean "list functions" section, then it would all need
;;;; to be defined without the use of destructuring macros, which make things
;;;; a lot nicer.

@boot

(defval .0 Ix0)
(defval .1 Ix1)
(defval .2 Ix2)
(defval .3 Ix3)
(defval .4 Ix4)
(defval .5 Ix5)
(defval .6 Ix6)
(defval .7 Ix7)
(defval .8 (Ix 8))
(defval .9 (Ix 9))
(defval .10 (Ix 10))
(defval .11 (Ix 11))
(defval .12 (Ix 12))
(defval .13 (Ix 13))
(defval .14 (Ix 14))
(defval .15 (Ix 15))

(defun (const x y) x)

(const 3 4)

(defun (assert-impl expr val)
  (Ifz (Eq 1 val)
    (Error ("assert" "fail" expr "has" (0 val "!=" 1)))
    expr))

(assert-impl (1 1) 1)
;(assert-impl (1 0) 0)

(defmacro (assert e x)
  xv(Ix1 x)
  (0 "assert-impl" (1 xv) xv))

(assert 1)
assert(1)

assert(Eq 1 (const 1 2))

assert(Lt 3 4)
assert(Le 3 4)
assert(Ne 3 4)
assert(Lt 3 4)
assert(Le 3 4)
assert(Ne 3 4)
assert(Le 4 4)
assert(Eq 4 4)
assert(Ge 4 4)

(defval not Nil)

