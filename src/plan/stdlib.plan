assert(Eq 0          (Trunc64 Trunc64))         ;  case
assert(Eq "Hello wo" (Trunc64 "Hello wo"))      ;  direct
assert(Eq "Hello wo" (Trunc64 "Hello world!"))  ;  indirect

;;; Nicer Syntax for Assertions ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

; `test' is a nicer version of assert which supports multiple tests in a
; single block and which uses planEq (which works with any PLAN value)
; instead of Eq (which only works with numbers).

(defun (tests-failure x1 v1 x2 v2)
  (Trace "ASSERTION FAILURE"
  (Trace "LEFT EXPR"
  (Trace x1
  (Trace "RIGHT EXPR"
  (Trace x2
  (Trace "LEFT VALUE"
  (Trace v1
  (Trace "RIGHT VALUE"
  (Trace v2
  (Error "assertion-failure")))))))))))

(defun (tests-loop checks n i)
  ck(Ix i checks)
  x1(Ix 0 ck)
  v1(Ix 1 ck)
  x2(Ix 2 ck)
  v2(Ix 3 ck)
  (Ifz (Lt i n) (0 n "tests" "passed")
    (Ifz (planEq v1 v2)
      (tests-failure x1 v1 x2 v2)
      (tests-loop checks n (Inc i)))))

(defun (tests-check checks)
  (tests-loop checks (Sz checks) 0))

(tests-check [["x1" 2 "x2" 2] ["x1" 5 "x2" 5]]) ; modify numbers to trigger an error

; tests
; =====
;
; (tests (5 5) (1 1))
;
; parse each test case
;
;     e@(x y)      [0 x y]
;     e@(#juxt x y) [0 "#juxt" x y]
;         => [x y]
;
; this input
;
;     (tests (a b) (c d))
;
; should expand to this:
;
;     [1[test-loop]
;      [1[0]
;       [1[a] a 1[b] b]
;       [1[c] c 1[d] d]]]

(defun (tests-malformed expr)
  (Error ("malformed test case" expr)))

(defun (tests-parse expr)
  sz(Sz expr)
  er(tests-malformed expr)
  e0(Ix 0 expr)
  e1(Ix 1 expr)
  e2(Ix 2 expr)
  (If (Hd expr) er
    (If (Eq 2 sz) [e0 e1]
      (Ifz (Eq 3 sz) er
        (Ifz (Eq "#juxt" e0) er
          [e1 e2])))))


;;; Quotation ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(defmacro (' env expr)
  (1 (Ix 1 expr)))


;;; Slicing ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(defun (slice-loop inp n ii oi acc)
  (If (Ge oi n) acc
    (slice-loop inp n (Inc ii) (Inc oi)
      (Up oi (Ix ii inp) acc))))

(defun (slice i n r)
  (slice-loop r n i 0
    (Rep 0 0 n)))

(defun (map-loop f x n i acc)
  (If (Ge i n) acc
    (map-loop f x n (Inc i)
      (Up i (f (Ix i x)) acc))))

(defun (map f x)
  n(Sz x)
  (map-loop f x n 0
    (Rep 0 0 n)))

(slice 3 3 [1 2 3 4 5 6 7 8 9])
(Force (map Inc [1 2 3]))

(defun (imap-loop f x n i acc)
  (If (Ge i n) acc
    (imap-loop f x n (Inc i)
      (Up i (f i (Ix i x)) acc))))

(defun (imap f x)
  n(Sz x)
  (imap-loop f x n 0
    (Rep 0 0 n)))

(defun (cons-loop xs n i acc)
  j(Inc i)
  (Seq j
    (If (Ge i n) acc
      (cons-loop xs n j
        (Up j (Ix i xs) acc)))))

(defun (cons x xs)
  n(Sz xs)
  (cons-loop xs n 0 (Rep 0 x (Inc n))))

(defun (rowE xs)
  (cons (1 0) xs))

(defun (tests-expr x)
  r(tests-parse x)
  e1(Ix 0 r)
  e2(Ix 1 r)
  (rowE [(1 e1) e1 (1 e2) e2]))

(defmacro (tests e x)
  [(1 tests-check)
   (rowE (map tests-expr (slice 1 (Dec (Sz x)) x)))])

(assert (Eq 1 (Dec (Sz [["tests"] ["x" "y"]]))))
(assert (planEq [(1 0) "a" "b" "c"] (rowE ["a" "b" "c"])))

