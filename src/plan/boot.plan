; Here we define wrappers for two BPLAN primitives, Ix, and Up.
;
; As you can see, the primop ABI is ((<"B"> (opname arg..)))

(#bind Ix
  (#pin
    (#law "Ix" (Ix i r)
      ((#pin "B") ("Ix" i r)))))

(#bind Up
  (#pin
    (#law "Up" (() i v r)
      ((#pin "B") ("Up" i v r)))))

; This is tedious, so we write a macro so that we can automate this
; boilerplate.
;
;     (bplan (Name arg..)) =>
;
;       (#bind Name
;         (#pin
;            (#law "Name" (Name arg..)
;              ((#pin B) ("Name" arg..))))

(#macro bplan
  (#pin
    (#law "bplan" (bplan e x)
      sig(Ix 1 x)
      nam(Ix 0 sig)
      (0 "#bind" nam
        (0 "#pin"
          (0 "#law" (1 nam) sig
            (0 (1 (#pin "B"))
              (Up 0 (1 nam) sig))))))))

