;;; RPLAN is for REPLs ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(#macro rplan
  (#pin
    (#law "rplan" (rplan e x)
      sig(Ix 1 x)
      nam(Ix 0 sig)
      (0 "#bind" nam
        (0 "#pin"
          (0 "#law" (1 nam) sig
            (0 (1 (#pin "R"))
              (Up 0 (1 nam) sig))))))))

(rplan (Input bytes))
(rplan (Output bytes))
(rplan (Warn bytes))
(rplan (ReadFile filename))
(rplan (Print val))
(rplan (Stamp path))
(rplan (Now _))


;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(#macro bind-value
  (#pin
    (#law "bind-value" (bind-value e x)
      (0 "#bind" (Ix1 x) (Ix2 x)))))

; (defun (name args..) body) =>
;
;     (def name (#pin (law (name args..) body)))

(bind-value bind-function
  (#pin
    (#law "bind-function" (bind-function isMacro e x)
      sigS(Ix 1 x)
      nmS(Ix 0 sigS)
      restS(Slice 2 (Sz x) x)
      nm(If (IsNat nmS) nmS (Ix 0 nmS))
      sig(Up 0 nm sigS)
      expr(0 "#pin" (Weld (0 "#law" (1 nm) sig) restS))
      (0 (If isMacro "#macro" "#bind") nm expr))))

(bind-function 0 0 (0 "defun" (0 "f" "x") "x"))

(#macro defun    (bind-function 0))
(#macro defmacro (bind-function 1))

(defun (print x)
  (Trace x x))

; x(y) => (#juxt x y) => (x y)

(defmacro (#juxt e x)
  (0 (Ix 1 x) (Ix 2 x)))

print(3)

(#macro defval bind-value)
(#macro =      bind-value)
(#macro def    bind-value)

(defun (Error e)
  (Trace ("Error" e)
    (Throw e)))
